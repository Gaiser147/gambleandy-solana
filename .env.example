# GANDY lottery — environment template.
# Copy to `.env` and fill in real values. `.env` is gitignored.

# Helius RPC API key — https://dashboard.helius.dev
HELIUS_API_KEY=your-helius-api-key

# Supabase project that stores payout history (table "Andy")
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Telegram bot for winner notifications — create via @BotFather
TELEGRAM_BOT_TOKEN=000000000:your-telegram-bot-token
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Absolute path to the Solana keypair JSON that withdraws transfer fees (fee.js).
# Keep this file inside keys/ (gitignored) — never commit a keypair.
FEE_AUTHORITY_KEYPAIR=/root/new-token/keys/your-fee-authority.json
