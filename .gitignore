# ===============================================
# GANDY Lottery — .gitignore
# Goal: publish only the GANDY lottery code; never leak secrets,
# runtime state, vendored third-party clones, or build artifacts.
# ===============================================

# --- Secrets & credentials (NEVER commit) ---
keys/
.env
.env.*
!.env.example
data/service-account-key.json

# --- Runtime state (regenerated by the pipeline; schema documented in data/README.md) ---
data/*.json

# --- Dependencies & lockfile (this project uses yarn) ---
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Vendored / cloned third-party projects (kept on disk, not part of this repo) ---
transfer-fee-demo/
solana-trading-bot/
cloud-wallet-bot/
SPL-wallet-generator/

# --- Superseded / dead clutter (kept on disk for reference, excluded from the repo) ---
_archive/
automation/
cron_sync_holder_command.sh
scripts/lottery/cron-swap.sh
api.py

# --- Binaries & archives ---
*.tar.gz

# --- Build & cache ---
dist/
build/
.cache/
.turbo/

# --- IDE, tooling & OS ---
.vscode/
.idea/
.serena/
.claude/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Logs & temp ---
*.log
logs/
*.tmp
*.temp
.tmp/
